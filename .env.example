# Copy this file to .env and fill in your values

# NVIDIA NIM API key (required) — https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-your-key-here

# Master API key for the api-server.js multi-tenant server (required)
MASTER_API_KEY=xc_master_your-secret-key-here

# NewsAPI key (optional) — https://newsapi.org/
NEWS_API_KEY=your-newsapi-key-here

# Signal Feed push — posts engaged tweets to aptum.fun/feed in real time
FEED_PUSH_URL=https://aptum.fun/feed.php
FEED_PUSH_SECRET=your-feed-secret-here
